local function mkToggle(parent, label, initVal, y, onChange)
    local row = Instance.new("Frame", parent)
    row.Size=UDim2.new(1,-20,0,28) row.Position=UDim2.new(0,10,0,y)
    row.BackgroundColor3=Color3.fromRGB(12,9,22) row.BorderSizePixel=0
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,7)
    mkLabel(row, label, 10, Color3.fromRGB(190,190,200), UDim2.new(0,10,0,0), UDim2.new(1,-56,1,0))
    local tgl = Instance.new("TextButton", row)
    tgl.Size=UDim2.new(0,40,0,20) tgl.Position=UDim2.new(1,-46,0.5,-10)
    tgl.Text=initVal and "ON" or "OFF"
    tgl.TextColor3=Color3.new(1,1,1) tgl.TextSize=9 tgl.Font=Enum.Font.GothamBold
    tgl.BackgroundColor3=initVal and Color3.fromRGB(40,180,90) or Color3.fromRGB(180,45,45)
    tgl.BorderSizePixel=0
    Instance.new("UICorner",tgl).CornerRadius=UDim.new(0,10)
    local val = initVal
    tgl.MouseButton1Click:Connect(function()
        val = not val
        tgl.Text=val and "ON" or "OFF"
        TweenService:Create(tgl,TweenInfo.new(0.2),{
            BackgroundColor3=val and Color3.fromRGB(40,180,90) or Color3.fromRGB(180,45,45)
        }):Play()
        if onChange then onChange(val) end
    end)
    return row, tgl
end

local function mkSlider(parent, label, min, max, initVal, y, onChange)
    local h = 44
    local cont = Instance.new("Frame", parent)
    cont.Size=UDim2.new(1,-20,0,h) cont.Position=UDim2.new(0,10,0,y)
    cont.BackgroundColor3=Color3.fromRGB(12,9,22) cont.BorderSizePixel=0
    Instance.new("UICorner",cont).CornerRadius=UDim.new(0,7)
    local valLbl = mkLabel(cont, label..": "..initVal, 10, Color3.fromRGB(190,190,200), UDim2.new(0,10,0,2), UDim2.new(1,-10,0,16))
    local track = Instance.new("Frame", cont)
    track.Size=UDim2.new(1,-20,0,6) track.Position=UDim2.new(0,10,0,26)
    track.BackgroundColor3=Color3.fromRGB(35,25,55) track.BorderSizePixel=0
    Instance.new("UICorner",track).CornerRadius=UDim.new(0,3)
    local fill = Instance.new("Frame", track)
    fill.Size=UDim2.new((initVal-min)/(max-min),0,1,0) fill.BackgroundColor3=Color3.fromRGB(130,60,255)
    fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(0,3)
    local knob = Instance.new("TextButton", track)
    knob.Size=UDim2.new(0,14,0,14) knob.AnchorPoint=Vector2.new(0.5,0.5)
    knob.Position=UDim2.new((initVal-min)/(max-min),0,0.5,0)
    knob.BackgroundColor3=Color3.fromRGB(200,150,255) knob.Text=""
    knob.BorderSizePixel=0
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    local dragging = false
    knob.MouseButton1Down:Connect(function() dragging=true end)
    UserInput.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    RunService.Heartbeat:Connect(function()
        if not dragging then return end
        local mp = UserInput:GetMouseLocation()
        local abs = track.AbsolutePosition
        local w   = track.AbsoluteSize.X
        local t   = math.clamp((mp.X-abs.X)/w,0,1)
        local v   = math.floor(min + t*(max-min))
        fill.Size = UDim2.new(t,0,1,0)
        knob.Position = UDim2.new(t,0,0.5,0)
        valLbl.Text = label..": "..v
        if onChange then onChange(v) end
    end)
    return cont
end

-- flash button
local function flash(btn, col)
    local orig = btn.BackgroundColor3
    btn.BackgroundColor3 = Color3.new(1,1,1)
    task.delay(0.1, function()
        TweenService:Create(btn,TweenInfo.new(0.2),{BackgroundColor3=col or orig}):Play()
    end)
end

