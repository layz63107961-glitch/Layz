-- ══════════════════════════════════════
--    AUTO-DETECTION (Heartbeat)
-- ══════════════════════════════════════

local cooldown = false

RunService.Heartbeat:Connect(function()
    if not CONFIG.AutoTPtoBase or cooldown then return end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if cooldown then break end

        local nameLower = obj.Name:lower()
        if nameLower:find(CONFIG.BrainrotTag:lower()) then

            local objPos
            if obj:IsA("BasePart") then
                objPos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                objPos = obj.PrimaryPart.Position
            end

            if objPos then
                local dist = (hrp.Position - objPos).Magnitude

                -- CAS 1: Tu es proche de la brainrot = tu la voles → TP à ta position
                if dist < 5 and CONFIG.SavedPosition then
                    cooldown = true
                    updateStatus("🧠 Brainrot volée! TP retour base...", Color3.fromRGB(255, 150, 50))
                    task.delay(0.4, function()
                        teleportTo(CONFIG.SavedPosition)
                        updateStatus("✅ TP retour effectué !", Color3.fromRGB(100, 255, 150))
                        task.delay(3, function()
                            cooldown = false
                            updateStatus("🔍 Scan actif...", Color3.fromRGB(180, 180, 180))
                        end)
                    end)
                    break
                end

                -- CAS 2: Brainrot dans ta base → TP dans ta base
                local myBase = workspace:FindFirstChild(CONFIG.BaseTag)
                    or workspace:FindFirstChild(LocalPlayer.Name .. "Base")
                    or workspace:FindFirstChild(LocalPlayer.Name .. "_Base")
                    or workspace:FindFirstChild(LocalPlayer.Name)

                if myBase then
                    local basePart = myBase:IsA("BasePart") and myBase
                        or (myBase:IsA("Model") and myBase.PrimaryPart)

                    if basePart then
                        local distToBase = (basePart.Position - objPos).Magnitude
                        if distToBase < CONFIG.DetectionRadius then
                            cooldown = true
                            updateStatus("🏠 Brainrot dans ta base! TP...", Color3.fromRGB(255, 100, 200))
                            task.delay(0.3, function()
                                teleportTo(basePart.Position + Vector3.new(0, 5, 0))
                                updateStatus("🏠 TP dans ta base !", Color3.fromRGB(255, 150, 255))
                                task.delay(3, function()
                                    cooldown = false
                                    updateStatus("🔍 Scan actif...", Color3.fromRGB(180, 180, 180))
                                end)
                            end)
                            break
                        end
                    end
                end
            end
        end
    end
end)

