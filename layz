local function getMyPlot()
    local plots = workspace:FindFirstChild("Plots") if not plots then return nil end
    for _, p in ipairs(plots:GetChildren()) do
        for _, vname in ipairs({"Owner","OwnerName","PlayerName"}) do
            local v = p:FindFirstChild(vname)
            if v and v.Value == LP.Name then return p end
        end
        for _, vname in ipairs({"OwnerId","OwnerID"}) do
            local v = p:FindFirstChild(vname)
            if v and tostring(v.Value) == tostring(LP.UserId) then return p end
        end
    end
    return nil
end

local function amICarrying()
    local c = LP.Character if not c then return false end
    for _, v in ipairs(c:GetChildren()) do
        if v:IsA("Model") then return true end
        if v:IsA("StringValue") and v.Name:lower():find("carry") then return true end
    end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if hrp then
        for _, v in ipairs(hrp:GetChildren()) do
            if (v:IsA("Weld") or v:IsA("WeldConstraint")) then
                local p0,p1 = v.Part0, v.Part1
                if p1 and not c:IsAncestorOf(p1) then return true end
                if p0 and not c:IsAncestorOf(p0) then return true end
            end
        end
    end
    for _, vname in ipairs({"Carrying","HasAnimal","IsCarrying"}) do
        local v = c:FindFirstChild(vname) or LP:FindFirstChild(vname)
        if v and v:IsA("BoolValue") then return v.Value end
    end
    return false
end

local function getAllBrainrots()
    local list = {}
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        for _, plot in ipairs(plots:GetChildren()) do
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                for _, pod in ipairs(podiums:GetChildren()) do
                    local animal = pod:FindFirstChildWhichIsA("Model") or pod:FindFirstChildWhichIsA("BasePart")
                    if animal then
                        local part = animal:IsA("BasePart") and animal
                            or (animal:IsA("Model") and (animal.PrimaryPart or animal:FindFirstChildWhichIsA("BasePart")))
                        if part then
                            -- Cherche le nom du brainrot
                            local name = animal.Name ~= "Model" and animal.Name or pod.Name
                            table.insert(list, {part=part, name=name, plot=plot})
                        end
                    end
                end
            end
        end
    end
    -- Fallback: cherche dans tout le workspace
    if #list == 0 then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (
                obj.Name:lower():find("brainrot") or
                obj.Name:lower():find("animal") or
                obj.Name:lower():find("character")
            ) then
                table.insert(list, {part=obj, name=obj.Name, plot=nil})
            end
        end
    end
    return list
end

