-- ══════════════════════════════════════
--  DETECTION AUTO (Heartbeat)
--
--  Dans Steal a Brainrot:
--  - workspace.Plots[i].Base = la base du plot
--  - workspace.Plots[i].AnimalPodiums = les brainrots
--  - Quand on vole, le perso a un weld ou un attribut
-- ══════════════════════════════════════

local wasCarrying = false

RunService.Heartbeat:Connect(function()
    if not AutoTP then return end
    if Cooldown then return end

    local nowCarrying = amICarrying()

    -- Met à jour le label de statut de portage
    if nowCarrying ~= wasCarrying then
        wasCarrying = nowCarrying
        if nowCarrying then
            CarryLabel.Text = "🔴 Tu portes un brainrot !"
            CarryLabel.TextColor3 = Color3.fromRGB(255,80,80)
        else
            CarryLabel.Text = "🔵 Pas en train de voler"
            CarryLabel.TextColor3 = Color3.fromRGB(100,100,140)
        end
    end

    -- CAS 1: Je viens de prendre un brainrot → TP immédiatement à ma base sauvée
    if nowCarrying and not Cooldown and SavedPos then
        Cooldown = true
        setStatus("🧠 Vol détecté ! TP vers ta base...", Color3.fromRGB(255,140,40))
        task.delay(0.3, function()
            tpTo(SavedPos)
            setStatus("✅ TP retour base effectué !", Color3.fromRGB(80,240,130))
            task.delay(4, function()
                Cooldown = false
                setStatus("🔍 Scan actif...", Color3.fromRGB(170,170,170))
            end)
        end)
        return
    end

    -- CAS 2: Un brainrot vient d'arriver dans MA BASE → TP dans ma base
    if not Cooldown then
        local myPlot = getMyPlot()
        if myPlot then
            local basePart = myPlot:FindFirstChild("Base")
                or myPlot:FindFirstChild("Spawn")
                or myPlot.PrimaryPart
                or (myPlot:IsA("BasePart") and myPlot)

            if basePart then
                local bpos = basePart:IsA("BasePart") and basePart.Position
                    or (basePart:IsA("Model") and basePart.PrimaryPart and basePart.PrimaryPart.Position)

                if bpos then
                    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and (hrp.Position - bpos).Magnitude > 30 then
                        -- Cherche brainrot récemment arrivé dans la base
                        local podiums = myPlot:FindFirstChild("AnimalPodiums")
                        if podiums then
                            for _, pod in ipairs(podiums:GetChildren()) do
                                -- Un podium récemment occupé aura un animal
                                local animal = pod:FindFirstChildWhichIsA("Model")
                                    or pod:FindFirstChildWhichIsA("BasePart")
                                if animal then
                                    -- Vérifie si c'est récent via un attribut ou juste par présence
                                    local isNew = pod:GetAttribute("JustArrived")
                                        or pod:GetAttribute("NewAnimal")
                                    if isNew then
                                        Cooldown = true
                                        setStatus("🏠 Brainrot dans ta base ! TP...", Color3.fromRGB(255,100,200))
                                        task.delay(0.3, function()
                                            tpTo(bpos + Vector3.new(0, 4, 0))
                                            setStatus("🏠 TP dans ta base !", Color3.fromRGB(255,150,255))
                                            task.delay(4, function()
                                                Cooldown = false
                                                setStatus("🔍 Scan actif...", Color3.fromRGB(170,170,170))
                                            end)
                                        end)
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

