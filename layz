-- ══════════════════════════════════════
--  TROUVER MON PLOT (BASE)
--  Dans Steal a Brainrot: workspace.Plots -> chaque Plot a Owner
-- ══════════════════════════════════════
local function getMyPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        -- Le plot peut avoir un StringValue "Owner" ou une valeur similaire
        local owner = plot:FindFirstChild("Owner")
            or plot:FindFirstChild("OwnerName")
            or plot:FindFirstChild("PlayerName")
        if owner and owner.Value == LP.Name then
            return plot
        end
        -- Fallback: cherche par UserId
        local ownerId = plot:FindFirstChild("OwnerId") or plot:FindFirstChild("OwnerID")
        if ownerId and tostring(ownerId.Value) == tostring(LP.UserId) then
            return plot
        end
    end
    return nil
end

-- ══════════════════════════════════════
--  TELEPORT (compatible Xeno)
-- ══════════════════════════════════════
local function tpTo(pos)
    local char = LP.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    -- Xeno supporte CFrame direct + sethiddenproperty
    if sethiddenproperty then
        pcall(sethiddenproperty, hrp, "CFrame", CFrame.new(pos))
    end
    hrp.CFrame = CFrame.new(pos)
end

-- ══════════════════════════════════════
--  DÉTECTION: est-ce que je porte qqch?
--  Dans SAB, quand on vole, un objet est "welded" au perso
--  ou un BoolValue "IsCarrying" existe sur le perso
-- ══════════════════════════════════════
local function amICarrying()
    local char = LP.Character
    if not char then return false end
    -- Cherche un weld ou objet attaché qui ressemble à un brainrot
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Model") or (v:IsA("StringValue") and v.Name:lower():find("carry")) then
            return true
        end
    end
    -- Cherche dans HRP
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        for _, v in ipairs(hrp:GetChildren()) do
            if v:IsA("Weld") or v:IsA("WeldConstraint") then
                -- Si un weld pointe vers un objet hors du perso -> on porte qqch
                local part0 = v:IsA("Weld") and v.Part0 or v.Part0
                local part1 = v:IsA("Weld") and v.Part1 or v.Part1
                if part1 and not char:IsAncestorOf(part1) then return true end
                if part0 and not char:IsAncestorOf(part0) then return true end
            end
        end
    end
    -- Cherche un BoolValue "Carrying" / "HasAnimal" sur le joueur
    local carrying = char:FindFirstChild("Carrying")
        or char:FindFirstChild("HasAnimal")
        or char:FindFirstChild("IsCarrying")
        or LP:FindFirstChild("Carrying")
        or LP:FindFirstChild("HasAnimal")
    if carrying and carrying:IsA("BoolValue") then
        return carrying.Value
    end
    return false
end

