local function mkLabel(parent, text, size, col, pos, sz, bold, align)
    local l = Instance.new("TextLabel", parent)
    l.BackgroundTransparency=1 l.Text=text l.TextSize=size or 11
    l.TextColor3=col or Color3.fromRGB(200,200,200)
    l.Position=pos or UDim2.new(0,0,0,0) l.Size=sz or UDim2.new(1,0,1,0)
    l.Font=bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextXAlignment=align or Enum.TextXAlignment.Left l.TextWrapped=true
    return l
end

