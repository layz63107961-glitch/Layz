-- ══════════════════════════════════════
--  HEARTBEAT — toute la logique auto
-- ══════════════════════════════════════
local wasCarrying = false
local farmStep = 0
local farmBrainrots = {}
local farmIndex = 1
local farmPhase = "goto" -- "goto" | "return"
local espTimer = 0
local alertTimer = 0

RunService.Heartbeat:Connect(function(dt)
    local hrp = getHRP()
    local hum = getHum()

    -- ── Speed / Jump maintien ──
    if hum then
        if State.SpeedEnabled then hum.WalkSpeed = State.SpeedValue end
        if State.JumpEnabled  then hum.JumpPower  = State.JumpValue  end
        if State.NoFall and hum.Health < 100 then
            -- reset fall via health (simple)
        end
        if State.InfStamina then
            -- reset stamina si le jeu en a une
            local stam = LP.Character and LP.Character:FindFirstChild("Stamina")
            if stam and stam:IsA("NumberValue") then stam.Value = stam.Value < 5 and 100 or stam.Value end
        end
    end

    -- ── Auto-TP vol ──
    if State.AutoTP and hrp and not State.Cooldown then
        local nowCarrying = amICarrying()
        if nowCarrying ~= wasCarrying then
            wasCarrying = nowCarrying
            if nowCarrying then
                CarryLbl.Text="🔴 Tu portes un brainrot !"
                CarryLbl.TextColor3=Color3.fromRGB(255,80,80)
                if State.SavedPos then
                    State.Cooldown=true
                    setStatus("🧠 Vol ! TP retour base...",Color3.fromRGB(255,140,40))
                    task.delay(0.3,function()
                        tpTo(State.SavedPos)
                        setStatus("✅ TP base effectué !",Color3.fromRGB(80,240,130))
                        task.delay(4,function() State.Cooldown=false setStatus("🔍 Scan...",Color3.fromRGB(170,170,170)) end)
                    end)
                end
            else
                CarryLbl.Text="🔵 Pas en train de voler"
                CarryLbl.TextColor3=Color3.fromRGB(100,100,140)
            end
        end
    end

    -- ── ESP ──
    espTimer = espTimer + dt
    if State.ESPEnabled and espTimer > 0.5 then
        espTimer = 0
        -- Destroy old ESP
        for _, bb in ipairs(State.ESPObjects) do pcall(function() bb:Destroy() end) end
        State.ESPObjects = {}
        local brainrots = getAllBrainrots()
        for _, b in ipairs(brainrots) do
            if b.part and b.part.Parent then
                local bb = Instance.new("BillboardGui", b.part)
                bb.Size=UDim2.new(0,120,0,40) bb.StudsOffset=Vector3.new(0,3,0)
                bb.AlwaysOnTop=true bb.LightInfluence=0
                local tl = Instance.new("TextLabel", bb)
                tl.Size=UDim2.new(1,0,0.6,0) tl.BackgroundTransparency=1
                tl.Text=b.name tl.TextColor3=Color3.fromRGB(255,80,150)
                tl.TextSize=12 tl.Font=Enum.Font.GothamBold tl.TextStrokeTransparency=0.4
                local dl = Instance.new("TextLabel", bb)
                dl.Size=UDim2.new(1,0,0.4,0) dl.Position=UDim2.new(0,0,0.6,0)
                dl.BackgroundTransparency=1 dl.TextColor3=Color3.fromRGB(200,200,255)
                dl.TextSize=9 dl.Font=Enum.Font.Gotham dl.TextStrokeTransparency=0.5
                if hrp then
                    dl.Text=math.floor((hrp.Position-b.part.Position).Magnitude).." studs"
                end
                table.insert(State.ESPObjects, bb)
            end
        end
    elseif not State.ESPEnabled and #State.ESPObjects > 0 then
        for _,bb in ipairs(State.ESPObjects) do pcall(function() bb:Destroy() end) end
        State.ESPObjects={}
    end

    -- ── Auto-Farm ──
    if State.AutoFarm and hrp and State.SavedPos and not State.Cooldown then
        farmStep = farmStep + dt
        if farmStep > 1.5 then
            farmStep = 0
            if farmPhase == "goto" then
                farmBrainrots = getAllBrainrots()
                if #farmBrainrots == 0 then
                    FarmStatusLbl.Text="Aucun brainrot trouvé..."
                    FarmStatusLbl.TextColor3=Color3.fromRGB(200,100,100)
                else
                    if farmIndex > #farmBrainrots then farmIndex=1 end
                    local target = farmBrainrots[farmIndex]
                    if target and target.part and target.part.Parent then
                        tpTo(target.part.Position + Vector3.new(0,3,0))
                        FarmStatusLbl.Text="🎯 Vol: "..target.name
                        FarmStatusLbl.TextColor3=Color3.fromRGB(255,180,80)
                        farmPhase="return"
                        farmIndex=farmIndex+1
                    end
                end
            elseif farmPhase == "return" then
                tpTo(State.SavedPos)
                FarmStatusLbl.Text="🏠 Retour base..."
                FarmStatusLbl.TextColor3=Color3.fromRGB(100,200,255)
                farmPhase="goto"
            end
        end
    end

    -- ── Base Alert ──
    alertTimer = alertTimer + dt
    if State.BaseAlert and alertTimer > 1.5 then
        alertTimer = 0
        local myPlot = getMyPlot()
        local basePart = myPlot and (myPlot:FindFirstChild("Base") or myPlot.PrimaryPart)
        if basePart then
            local bpos = basePart:IsA("BasePart") and basePart.Position
                or (basePart.PrimaryPart and basePart.PrimaryPart.Position)
            if bpos then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LP then
                        local pc = plr.Character
                        local phrp = pc and pc:FindFirstChild("HumanoidRootPart")
                        if phrp then
                            local dist=(bpos-phrp.Position).Magnitude
                            if dist < getAlertRadius() then
                                if not State.AlertedPlayers[plr.Name] then
                                    State.AlertedPlayers[plr.Name]=true
                                    showNotif("⚠️ "..plr.Name.." approche ta base !")
                                    setStatus("🔔 ALERTE: "..plr.Name.." s'approche !",Color3.fromRGB(255,80,80))
                                end
                            else
                                State.AlertedPlayers[plr.Name]=nil
                            end
                        end
                    end
                end
            end
        end
    end
end)

