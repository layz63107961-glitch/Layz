-- ══════════════════════════════════════
--    DETECTION AUTO BRAINROT
-- ══════════════════════════════════════

--[[
    SYSTÈME DE DÉTECTION:
    
    1. Quand tu voles une brainrot (tu la prends / elle devient toi-owned),
       le système détecte cela et te TP à ta position sauvegardée.
    
    2. Quand une brainrot arrive dans TA BASE,
       le système te TP dans ta base.
    
    Adapte les noms/tags selon ton jeu :
    - CONFIG.BrainrotTag = nom ou tag des objets brainrot
    - CONFIG.BaseTag = nom ou tag de ta base
]]

local stealCooldown = false

RunService.Heartbeat:Connect(function()
    if not CONFIG.AutoTPtoBase then return end
    if stealCooldown then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- ── Détection: Brainrot volée → TP à ma position ──
    -- Cherche dans Workspace les objets brainrot proches du joueur
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find(CONFIG.BrainrotTag:lower()) then
            -- Vérifie si la brainrot est proche et vient d'être "touchée" / prise
            local objPos = nil
            if obj:IsA("BasePart") then
                objPos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                objPos = obj.PrimaryPart.Position
            end

            if objPos then
                local dist = (hrp.Position - objPos).Magnitude
                -- Si la brainrot est très proche (on la "vol")
                if dist < 5 then
                    if CONFIG.SavedPosition then
                        stealCooldown = true
                        updateStatus("🧠 Brainrot volée! TP vers ta base...", Color3.fromRGB(255, 150, 50))
                        task.delay(0.5, function()
                            teleportTo(CONFIG.SavedPosition)
                            updateStatus("✅ TP effectué après vol !", Color3.fromRGB(100, 255, 150))
                            task.delay(3, function()
                                stealCooldown = false
                                updateStatus("🔍 Scan en cours...", Color3.fromRGB(200, 200, 200))
                            end)
                        end)
                    end
                end
            end
        end
    end

    -- ── Détection: Brainrot dans ma base → TP dans ma base ──
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find(CONFIG.BrainrotTag:lower()) then
            -- Cherche la base du joueur
            local myBase = workspace:FindFirstChild(CONFIG.BaseTag)
                or workspace:FindFirstChild(LocalPlayer.Name .. "Base")
                or workspace:FindFirstChild(LocalPlayer.Name .. "_Base")
            
            if myBase then
                local basePart = myBase:IsA("BasePart") and myBase 
                    or (myBase:IsA("Model") and myBase.PrimaryPart)
                    
                if basePart then
                    local objPos = nil
                    if obj:IsA("BasePart") then
                        objPos = obj.Position
                    elseif obj:IsA("Model") and obj.PrimaryPart then
                        objPos = obj.PrimaryPart.Position
                    end
                    
                    if objPos then
                        local distToBase = (basePart.Position - objPos).Magnitude
                        -- Brainrot est dans/près de la base
                        if distToBase < CONFIG.DetectionRadius then
                            stealCooldown = true
                            updateStatus("🏠 Brainrot dans ta base! TP en cours...", Color3.fromRGB(255, 100, 200))
                            task.delay(0.3, function()
                                -- TP directement dans la base
                                teleportTo(basePart.Position + Vector3.new(0, 5, 0))
                                updateStatus("🏠 TP dans ta base effectué !", Color3.fromRGB(255, 150, 255))
                                task.delay(3, function()
                                    stealCooldown = false
                                    updateStatus("🔍 Scan en cours...", Color3.fromRGB(200, 200, 200))
                                end)
                            end)
                        end
                    end
                end
            end
        end
    end
end)

