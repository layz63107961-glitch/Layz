-- Helper: crée une section
local function Section(title, h, order)
    local s = Instance.new("Frame", Content)
    s.Size = UDim2.new(1, 0, 0, h)
    s.BackgroundColor3 = Color3.fromRGB(20, 15, 35)
    s.BorderSizePixel = 0
    s.LayoutOrder = order
    Instance.new("UICorner", s).CornerRadius = UDim.new(0, 8)
    local stroke = Instance.new("UIStroke", s)
    stroke.Color = Color3.fromRGB(60, 40, 80)
    stroke.Thickness = 1
    local lbl = Instance.new("TextLabel", s)
    lbl.Size = UDim2.new(1, -10, 0, 20)
    lbl.Position = UDim2.new(0, 10, 0, 5)
    lbl.BackgroundTransparency = 1
    lbl.Text = title
    lbl.TextColor3 = Color3.fromRGB(200, 150, 255)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    return s
end

-- Helper: crée un bouton
local function MakeBtn(parent, text, color, y, h)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -20, 0, h or 32)
    btn.Position = UDim2.new(0, 10, 0, y)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    return btn
end

