local function switchTab(name)
    ActiveTab = name
    for n, page in pairs(TabPages) do
        page.Visible = (n==name)
    end
    for n, tb in pairs(TabBtns) do
        TweenService:Create(tb,TweenInfo.new(0.15),{
            BackgroundColor3 = n==name and Color3.fromRGB(110,40,220) or Color3.fromRGB(20,15,35)
        }):Play()
    end
end
for name, tb in pairs(TabBtns) do
    tb.MouseButton1Click:Connect(function() switchTab(name) end)
end

